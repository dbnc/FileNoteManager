<Window x:Class="FileNoteManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📝 File Note Manager"
        Height="640" Width="1024"
        MinHeight="550" MinWidth="800"
        Background="#F5F5F5">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveNoteCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════
             TOOLBAR
        ════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="8,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="📝 File Note Manager"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="4,0,20,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📥 导入" Command="{Binding ImportCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="📤 导出 JSON" Command="{Binding ExportJsonCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="📤 导出 CSV" Command="{Binding ExportCsvCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Separator Style="{StaticResource ToolbarSeparatorStyle}" />
                    <Button Content="💾 备份" Command="{Binding CreateBackupCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Separator Style="{StaticResource ToolbarSeparatorStyle}" />
                    <Button Content="✅ 注册右键菜单" Command="{Binding RegisterShellCommand}"
                            Visibility="{Binding IsShellRegistered, Converter={StaticResource InverseBoolToVis}}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="❌ 注销右键菜单" Command="{Binding UnregisterShellCommand}"
                            Visibility="{Binding IsShellRegistered, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom" Background="#ECF0F1" BorderThickness="0,1,0,0"
                BorderBrush="#BDC3C7" Padding="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Foreground="#7F8C8D" FontSize="11"
                           Text="{Binding LastBackupDisplay, StringFormat='最后备份: {0}'}" />
                <TextBlock DockPanel.Dock="Right" Foreground="#7F8C8D" FontSize="11"
                           Margin="0,0,20,0"
                           Text="{Binding DatabaseSizeDisplay, StringFormat='数据库: {0}'}" />
                <TextBlock Foreground="#2C3E50" FontSize="11"
                           Text="{Binding TotalNotes, StringFormat='共 {0} 条备注'}" />
                <TextBlock Foreground="#27AE60" FontSize="11" Margin="20,0,0,0"
                           Text="{Binding StatusMessage}" />
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             MAIN CONTENT: Left panel + Splitter + Editor
        ════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────
                 LEFT PANEL: Search + Note List
            ───────────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="White">

                <!-- Search box -->
                <Border DockPanel.Dock="Top" Background="#F8F9FA"
                        BorderThickness="0,0,0,1" BorderBrush="#DEE2E6" Padding="8,6">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="White" BorderBrush="#CED4DA"
                                 Padding="24,5,8,5" FontSize="12"
                                 ToolTip="搜索备注内容、标签或文件名 (Ctrl+F)">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock IsHitTestVisible="False" Text="🔍 搜索备注..."
                                   Foreground="#ADB5BD" FontSize="12"
                                   Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Notes ListView -->
                <ListView ItemsSource="{Binding Notes}"
                          SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                          BorderThickness="0" Background="White"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E8F4FD"/>
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               FontSize="12" Foreground="#2C3E50"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ContentPreview}"
                                           FontSize="11" Foreground="#7F8C8D"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="17,0,0,2"/>
                                <StackPanel Orientation="Horizontal" Margin="17,0,0,0">
                                    <TextBlock Text="{Binding TagsDisplay}"
                                               FontSize="10" Foreground="#3498DB"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding UpdatedDisplay}"
                                               FontSize="10" Foreground="#BDC3C7"
                                               HorizontalAlignment="Right"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="#DEE2E6" Cursor="SizeWE"/>

            <!-- ─────────────────────────────────────────
                 RIGHT PANEL: Note Editor
            ───────────────────────────────────────── -->
            <Grid Grid.Column="2" Background="White">
                <!-- Disabled overlay when no note selected -->
                <TextBlock Text="← 从左侧选择一条备注进行编辑，或右键文件选择「编辑文件备注」"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#BDC3C7" FontSize="14" TextWrapping="Wrap"
                           Margin="40,0" TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditorEnabled}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <DockPanel IsEnabled="{Binding IsEditorEnabled}"
                           Margin="16,12">
                    <!-- Path header -->
                    <Border DockPanel.Dock="Top" Background="#F8F9FA"
                            BorderBrush="#DEE2E6" BorderThickness="1"
                            CornerRadius="4" Padding="10,7" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedNote.Icon, FallbackValue='📄'}"
                                       FontSize="11" Foreground="#6C757D"/>
                            <TextBlock Text="{Binding EditorPath}"
                                       FontSize="12" Foreground="#495057"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding EditorPath}"/>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾  保存备注" Command="{Binding SaveNoteCommand}"
                                    Background="#27AE60" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    FontSize="13" Cursor="Hand"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#27AE60"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#229954"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="�  打开位置" Command="{Binding OpenInExplorerCommand}"
                                    Background="#2980B9" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    FontSize="13" Cursor="Hand"
                                    Margin="0,0,8,0"
                                    ToolTip="在资源管理器中打开文件或文件夹所在位置">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2980B9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2471A3"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="�🗑  删除备注" Command="{Binding DeleteNoteCommand}"
                                    Background="#E74C3C" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    FontSize="13" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#CB4335"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Tags area -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="#DEE2E6"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,6" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="标签" FontSize="11" Foreground="#6C757D" Margin="0,0,0,4"/>
                            <WrapPanel x:Name="TagsPanel">
                                <ItemsControl ItemsSource="{Binding EditorTags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#E8F4FD" BorderBrush="#3498DB"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="8,3" Margin="3,3,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#2980B9"/>
                                                    <Button Content="×" FontSize="11"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="#2980B9" Padding="3,0,0,0" Cursor="Hand"
                                                            Command="{Binding DataContext.RemoveTagCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Tag input inline -->
                                <StackPanel Orientation="Horizontal" Margin="3,3,0,0">
                                    <TextBox Text="{Binding TagInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" FontSize="11" Padding="4,3"
                                             BorderBrush="#CED4DA" VerticalContentAlignment="Center">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding AddTagCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Content="+ 添加" Command="{Binding AddTagCommand}"
                                            FontSize="11" Padding="6,3" Margin="4,0,0,0"
                                            Background="#F8F9FA" BorderBrush="#CED4DA" Cursor="Hand"/>
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Content editor (fills remaining space) -->
                    <TextBox Text="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="13" FontFamily="Consolas, Segoe UI"
                             BorderBrush="#DEE2E6" Padding="10"
                             SpellCheck.IsEnabled="False"
                             VerticalContentAlignment="Top"/>
                </DockPanel>
            </Grid>

        </Grid>
    </DockPanel>
</Window>
