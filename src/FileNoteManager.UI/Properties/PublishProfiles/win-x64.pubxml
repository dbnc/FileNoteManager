<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: compact framework-dependent package (requires .NET 8 on target machine).
  Output: src/FileNoteManager.UI/publish/

  To publish from terminal:
    dotnet publish src/FileNoteManager.UI/FileNoteManager.UI.csproj -p:PublishProfile=win-x64

  To publish self-contained (no .NET 8 needed, ~100 MB):
    dotnet publish src/FileNoteManager.UI/FileNoteManager.UI.csproj -p:PublishProfile=win-x64 -p:SelfContained=true
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>AnyCPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishDir>publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <!-- Keep shell DLLs next to the EXE — comhost.dll must be at a stable path for COM -->
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <!-- Exclude shell DLLs from single-file bundling so comhost can find them -->
  <ItemGroup>
    <ExcludeFromSingleFile Include="FileNoteManager.Shell.dll" />
    <ExcludeFromSingleFile Include="FileNoteManager.Core.dll" />
    <ExcludeFromSingleFile Include="FileNoteManager.Shell.comhost.dll" />
    <ExcludeFromSingleFile Include="FileNoteManager.Shell.runtimeconfig.json" />
    <ExcludeFromSingleFile Include="FileNoteManager.Shell.deps.json" />
    <ExcludeFromSingleFile Include="Microsoft.Data.Sqlite.dll" />
    <ExcludeFromSingleFile Include="Dapper.dll" />
    <ExcludeFromSingleFile Include="CsvHelper.dll" />
    <ExcludeFromSingleFile Include="SQLitePCLRaw.*.dll" />
    <ExcludeFromSingleFile Include="e_sqlite3.dll" />
  </ItemGroup>
</Project>
