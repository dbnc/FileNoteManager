<Window x:Class="FileNoteManager.UI.Views.QuickNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 文件备注"
        Width="440" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.InputBindings>
        <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <DockPanel Margin="14,12">

        <!-- File path header -->
        <Border DockPanel.Dock="Top" Background="#F8F9FA" BorderBrush="#DEE2E6"
                BorderThickness="1" CornerRadius="4" Padding="10,7" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                           FontSize="13" Foreground="#2C3E50"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding FilePath}" FontSize="10" Foreground="#7F8C8D"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"/>
            </StackPanel>
        </Border>

        <!-- Buttons at bottom -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="💾  保存并关闭" Command="{Binding SaveCommand}"
                        Background="#27AE60" Foreground="White" BorderThickness="0"
                        Padding="14,8" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#27AE60"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#229954"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="🗑  删除"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding HasExistingNote}"
                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                        Padding="12,8" FontSize="13" Cursor="Hand" Margin="6,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E74C3C"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CB4335"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#F5B7B1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="取消" Command="{Binding CancelCommand}"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        Padding="12,8" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#95A5A6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7F8C8D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Tags -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DEE2E6" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="标签 (回车添加)" FontSize="10" Foreground="#6C757D" Margin="0,0,0,4"/>
                <WrapPanel>
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E8F4FD" BorderBrush="#3498DB"
                                        BorderThickness="1" CornerRadius="10"
                                        Padding="7,2" Margin="0,2,4,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#2980B9"/>
                                        <Button Content="×" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#2980B9" Padding="3,0,0,0" Cursor="Hand"
                                                Command="{Binding DataContext.RemoveTagCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBox Text="{Binding TagInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" FontSize="11" Padding="4,2" BorderBrush="#CED4DA">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddTagCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="+" Command="{Binding AddTagCommand}"
                                FontSize="12" Padding="6,2" Margin="4,0,0,0"
                                Background="#F8F9FA" BorderBrush="#CED4DA" Cursor="Hand"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Content TextBox (fills remaining height) -->
        <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontSize="13" BorderBrush="#DEE2E6" Padding="8"
                 VerticalContentAlignment="Top"
                 x:Name="ContentBox"/>
    </DockPanel>
</Window>
