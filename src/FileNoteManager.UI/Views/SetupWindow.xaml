<Window x:Class="FileNoteManager.UI.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Note Manager — 初次设置"
        Width="500" SizeToContent="Height"
        MinHeight="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main content -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="36,32,36,20">

            <!-- Icon + title -->
            <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="File Note Manager" FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="为文件和文件夹添加备注的工具"
                       FontSize="12" Foreground="#7F8C8D"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <!-- Explain what registration does -->
            <Border Background="#EBF5FB" BorderBrush="#AED6F1" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="注册右键菜单后，在任意文件或文件夹上右键，即可看到「编辑文件备注」选项。"
                               FontSize="12" Foreground="#2C3E50" TextWrapping="Wrap"/>
                    <TextBlock Text="✔ 仅写入当前用户注册表，无需管理员权限"
                               FontSize="11" Foreground="#1A5276" Margin="0,6,0,0"/>
                    <TextBlock Text="✔ 可随时从主界面注销"
                               FontSize="11" Foreground="#1A5276" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Register button -->
            <Button x:Name="RegisterButton"
                    Content="✅  立即注册右键菜单"
                    Click="RegisterButton_Click"
                    FontSize="15" FontWeight="SemiBold"
                    Foreground="White" Background="#2980B9"
                    BorderThickness="0" Padding="0,14"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2980B9"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2471A3"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A5276"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Skip link at bottom -->
        <Border Grid.Row="1" Padding="0,0,0,16">
            <TextBlock HorizontalAlignment="Center">
                <Hyperlink x:Name="SkipLink" Click="SkipLink_Click" Foreground="#ADB5BD">
                    暂不注册，直接进入主界面
                </Hyperlink>
            </TextBlock>
        </Border>
    </Grid>
</Window>
